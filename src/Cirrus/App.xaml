<Application
    x:Class="Cirrus.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winui="using:Windows.UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Commanding/Commands.xaml" />
                <ResourceDictionary Source="Converters/Converters.xaml" />
                <ResourceDictionary Source="Controls/TemplatedControls.xaml" />
                <ResourceDictionary Source="Themes/ControlStyles.xaml" />
                <ResourceDictionary Source="Themes/SharedResources.xaml" />
                <ResourceDictionary Source="Resources/CommonResources.xaml" />
                <ResourceDictionary Source="Resources/FontIcons.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="ExplicitIconForeground" Color="{ThemeResource SystemBaseMediumColor}" />
            <winui:Color x:Key="SystemAccentColorLight3">#E5F0FF</winui:Color>
            <winui:Color x:Key="SystemAccentColorLight2">#99C2FF</winui:Color>
            <winui:Color x:Key="SystemAccentColorLight1">#4D94FF</winui:Color>
            <winui:Color x:Key="SystemAccentColor">#0066FF</winui:Color>
            <winui:Color x:Key="SystemAccentColorDark1">#0047B2</winui:Color>
            <winui:Color x:Key="SystemAccentColorDark2">#002966</winui:Color>
            <winui:Color x:Key="SystemAccentColorDark3">#000A1A</winui:Color>
            <AcrylicBrush x:Key="AltColorAcrylicControlBackgroundBrush"
                          TintColor="{ThemeResource SystemAltHighColor}" TintOpacity="0.6" />
            <SolidColorBrush x:Key="TeachingTipTransientBackground" Color="{ThemeResource SolidBackgroundFillColorTertiary}" />
            <x:Double x:Key="TeachingTipMinHeight">40</x:Double>
            <x:Double x:Key="TeachingTipMaxHeight">600</x:Double>
            <x:Double x:Key="TeachingTipMinWidth">300</x:Double>
            <x:Double x:Key="TeachingTipMaxWidth">500</x:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>