<local:SoftwareUpdateViewBase
    x:Class="Cirrus.Views.SoftwareUpdateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Cirrus.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:Cirrus.Behaviors"
    xmlns:comPrim="using:Cirrus.Commanding.Primitives"
    xmlns:communityControls="using:CommunityToolkit.WinUI.Controls"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:models="using:Cirrus.Models.Business.Developer"
    mc:Ignorable="d">
    <Page.Resources>
        <comPrim:CommandWrapper x:Key="DownloadPackageCommand" InnerCommand="{x:Bind ViewModel.DownloadUpdateCommand}" />
        <communityControls:MarkdownConfig x:Key="DefaultMarkdownConfig" />
    </Page.Resources>
    <interactivity:Interaction.Behaviors>
        <behaviors:LoadedEventTriggerBehavior>
            <interactivity:InvokeCommandAction Command="{x:Bind LoadedCommand}" />
        </behaviors:LoadedEventTriggerBehavior>
    </interactivity:Interaction.Behaviors>
    <Grid>
        <Grid Canvas.ZIndex="1" Margin="16" MaxWidth="968" VerticalAlignment="Top">
            <Border x:Name="HeaderFloatingBackBorder"
                    Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefault}" BorderThickness="1"
                    CornerRadius="8" Height="80" Margin="16 0"
                    Opacity="1">
            </Border>
            <Border VerticalAlignment="Center">
                <TextBlock x:Name="HeaderTextBlock" x:Uid="Views/SoftwareUpdateView/HeaderTextBlock"
                           CharacterSpacing="-20" FontSize="24" FontWeight="Bold" MaxLines="2"
                           TextTrimming="CharacterEllipsis" TextWrapping="Wrap" />
            </Border>
        </Grid>
        <ScrollViewer x:Name="RootScrollViewer" MaxWidth="1000">
            <StackPanel Margin="16 112 16 92">
                <Grid Padding="20 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border CornerRadius="40" Width="80" Height="80"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="{x:Bind ViewModel.IndicatorBackgroundColor, Mode=OneWay}" />
                        </Border.Background>
                        <FontIcon FontFamily="{StaticResource CirrusIconSetFontFamily}"
                                  Glyph="{x:Bind ViewModel.IndicatorIconGlyph, Mode=OneWay}" Foreground="#CCFFFFFF"
                                  FontSize="60"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12 0">
                        <TextBlock Text="{x:Bind ViewModel.IndicatorText, Mode=OneWay}" TextWrapping="Wrap"
                                   FontSize="20" FontWeight="Medium" />
                        <TextBlock Text="{x:Bind ViewModel.LastCheckedTime, Mode=OneWay}" TextWrapping="Wrap"
                                   FontSize="16" FontWeight="Normal"
                                   Visibility="{x:Bind ViewModel.IsChecking, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True, Mode=OneWay}" />
                        <ProgressBar HorizontalAlignment="Stretch" Margin="0 8 0 0" IsIndeterminate="True"
                                     Visibility="{x:Bind ViewModel.IsChecking, Mode=OneWay}" />
                    </StackPanel>
                    <Button x:Uid="Views/SoftwareUpdateView/CheckForUpdatesButton"
                            Style="{ThemeResource AccentButtonStyle}" Foreground="White" Grid.Column="2"
                            VerticalAlignment="Center" Command="{x:Bind ViewModel.GetUpdatesCommand}"
                            IsEnabled="{x:Bind ViewModel.IsChecking, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
                </Grid>
                <ListView Margin="8 0" ItemsSource="{x:Bind ViewModel.AvailableUpdates}"
                          SelectionMode="None" IsItemClickEnabled="False"
                          Visibility="{x:Bind ViewModel.IsChecking, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True, Mode=OneWay}">
                    <ListView.Header>
                        <TextBlock x:Uid="SoftwareUpdateViewAvailablePackagesTextBlock" FontSize="16"
                                   FontWeight="Medium" Margin="24 12" />
                    </ListView.Header>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Style.Setters>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style.Setters>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ISoftwareUpdate">
                            <Expander HorizontalAlignment="Stretch" Margin="0 4"
                                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                      HorizontalContentAlignment="Left"
                                      IsExpanded="False">
                                <Expander.Header>
                                    <Grid Margin="0 0 -12 0">
                                        <StackPanel Padding="0 12">
                                            <TextBlock Text="{x:Bind VersionHeader}" FontSize="16" FontWeight="Medium" />
                                            <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                                <Border Background="#E64C4C" Padding="8 2" CornerRadius="4"
                                                        Margin="0 0 4 0">
                                                    <TextBlock Text="{x:Bind Architecture}" Foreground="White"
                                                               FontWeight="Medium" FontSize="12" />
                                                </Border>
                                                <Border Background="#4CAFE6" Padding="8 2" CornerRadius="4"
                                                        Margin="0 0 4 0"
                                                        Visibility="{x:Bind IsPublic}">
                                                    <TextBlock Text="Public" Foreground="White" FontWeight="Medium"
                                                               FontSize="12" />
                                                </Border>
                                                <Border Background="#874CE6" Padding="8 2" CornerRadius="4"
                                                        Visibility="{x:Bind IsInPreview}">
                                                    <TextBlock Text="Preview" Foreground="White" FontWeight="Medium"
                                                               FontSize="12" />
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                    Visibility="{x:Bind IsEnabled}" Spacing="4">
                                            <Button x:Uid="Views/SoftwareUpdateView/DownloadButton"
                                                    Command="{StaticResource DownloadPackageCommand}"
                                                    CommandParameter="{x:Bind}" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <Expander.Content>
                                    <Grid>
                                        <communityControls:MarkdownTextBlock Text="{x:Bind ReleaseNotes}"
                                                                             Config="{StaticResource DefaultMarkdownConfig}"
                                                                             HorizontalAlignment="Left" />
                                    </Grid>
                                </Expander.Content>
                            </Expander>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Grid Grid.Row="2" Margin="4 0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Uid="Views/SoftwareUpdateView/AdditionalOptionsTextBlock" FontSize="16"
                               FontWeight="Medium"
                               Margin="28 12" />
                    <StackPanel Margin="16 0" Grid.Row="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderThickness="1" BorderBrush="{StaticResource CardStrokeColorDefaultBrush}"
                                CornerRadius="4" Padding="16">
                        <CheckBox x:Uid="Views/SoftwareUpdateView/EnablePreviewCheckBox"
                                  IsChecked="{x:Bind ViewModel.ArePreviewBuildsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</local:SoftwareUpdateViewBase>