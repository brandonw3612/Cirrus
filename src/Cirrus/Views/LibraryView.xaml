<local:LibraryViewBase
    x:Class="Cirrus.Views.LibraryView"
    x:Name="CurrentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Cirrus.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:albumModels="using:Cirrus.Models.Network.Album"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:artistModels="using:Cirrus.Models.Network.Artist"
    xmlns:behaviors="using:Cirrus.Behaviors"
    xmlns:communityControls="using:CommunityToolkit.WinUI.Controls"
    xmlns:controls="using:Cirrus.Controls"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:layout="using:Cirrus.Layout"
    xmlns:themes="using:Cirrus.Themes"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="LibraryAlbumItemTemplate" x:DataType="albumModels:AlbumDetail2">
            <controls:NavigatiableDisplayCard Title="{x:Bind Title}"
                                              Subtitle="{x:Bind Artists, Converter={StaticResource MultipleEntityNamesConverter}}"
                                              Image="{x:Bind ArtworkImageUrl, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=480}"
                                              DataContext="{Binding Mode=OneWay}" />
        </DataTemplate>
        <DataTemplate x:Key="LibraryArtistItemTemplate" x:DataType="artistModels:ArtistDetail">
            <controls:NavigatiableDisplayCard Style="{StaticResource CircleNavigationDisplayCardStyle}"
                                              CornerRadius="80"
                                              Image="{x:Bind AvatarImageUrl, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=320}"
                                              Title="{x:Bind Name}"
                                              DataContext="{Binding Mode=OneWay}" />
        </DataTemplate>
    </Page.Resources>
    <Grid>
        <interactivity:Interaction.Behaviors>
            <behaviors:LoadedEventTriggerBehavior>
                <interactivity:InvokeCommandAction Command="{x:Bind LoadedCommand}" />
            </behaviors:LoadedEventTriggerBehavior>
            <behaviors:SizeChangedEventTriggerBehavior>
                <interactivity:InvokeCommandAction Command="{x:Bind ViewModel.SizeChangedCommand}" />
            </behaviors:SizeChangedEventTriggerBehavior>
        </interactivity:Interaction.Behaviors>
        <ProgressBar VerticalAlignment="Top" Canvas.ZIndex="2"
                     Background="Transparent"
                     IsIndeterminate="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        <Border x:Name="FloatingHeader"
                Canvas.ZIndex="1"
                VerticalAlignment="Top" HorizontalAlignment="Stretch" MaxWidth="1000"
                Visibility="Collapsed"
                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                CornerRadius="4" Margin="32 16" Padding="24">
            <animations:Implicit.ShowAnimations>
                <animations:TranslationAnimation From="0,-120,0" To="0" Duration="0:0:0.300" />
            </animations:Implicit.ShowAnimations>
            <animations:Implicit.HideAnimations>
                <animations:TranslationAnimation From="0" To="0,-120,0" Duration="0:0:0.300" />
            </animations:Implicit.HideAnimations>
            <layout:Row
                Spacing="16" HorizontalAlignment="Stretch">
                <TextBlock x:Uid="Views/LibraryView/Header"
                           CharacterSpacing="-20" FontSize="24" FontWeight="Bold"
                           VerticalAlignment="Center" />
                <layout:Spacer layout:Row.ColumnWidth="*" />
                <communityControls:Segmented
                    SelectedIndex="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <communityControls:SegmentedItem x:Uid="Views/LibraryView/Categories/Albums">
                        <communityControls:SegmentedItem.Icon>
                            <FontIcon Glyph="&#xE93C;" />
                        </communityControls:SegmentedItem.Icon>
                    </communityControls:SegmentedItem>
                    <communityControls:SegmentedItem x:Uid="Views/LibraryView/Categories/Artists">
                        <communityControls:SegmentedItem.Icon>
                            <FontIcon Glyph="{ThemeResource FontIconGlyphArtist}"
                                      FontFamily="{ThemeResource CirrusIconSetFontFamily}" />
                        </communityControls:SegmentedItem.Icon>
                    </communityControls:SegmentedItem>
                </communityControls:Segmented>
            </layout:Row>
        </Border>
        <ListView x:Name="ContentListView" Padding="8 8 8 80"
                  ItemsSource="{x:Bind ViewModel.DisplayItems}">
            <ListView.ItemTemplateSelector>
                <themes:LibraryCollectionItemTemplateSelector
                    AlbumTemplate="{StaticResource LibraryAlbumItemTemplate}"
                    ArtistTemplate="{StaticResource LibraryArtistItemTemplate}" />
            </ListView.ItemTemplateSelector>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   ItemWidth="{Binding ElementName=CurrentView, Path=ViewModel.DisplayCardWidth, Mode=OneWay}" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter Padding="8" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.Header>
                <layout:Row x:Name="ViewHeader"
                            Margin="32"
                            Spacing="16" HorizontalAlignment="Stretch">
                    <animations:Implicit.Animations>
                        <animations:OpacityAnimation Duration="0:0:0.300" />
                    </animations:Implicit.Animations>
                    <TextBlock x:Uid="Views/LibraryView/Header"
                               CharacterSpacing="-20" FontSize="24" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <layout:Spacer layout:Row.ColumnWidth="*" />
                    <communityControls:Segmented
                        SelectedIndex="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <communityControls:SegmentedItem x:Uid="Views/LibraryView/Categories/Albums">
                            <communityControls:SegmentedItem.Icon>
                                <FontIcon Glyph="&#xE93C;" />
                            </communityControls:SegmentedItem.Icon>
                        </communityControls:SegmentedItem>
                        <communityControls:SegmentedItem x:Uid="Views/LibraryView/Categories/Artists">
                            <communityControls:SegmentedItem.Icon>
                                <FontIcon Glyph="{ThemeResource FontIconGlyphArtist}"
                                          FontFamily="{ThemeResource CirrusIconSetFontFamily}" />
                            </communityControls:SegmentedItem.Icon>
                        </communityControls:SegmentedItem>
                    </communityControls:Segmented>
                </layout:Row>
            </ListView.Header>
            <ListView.Footer>
                <Button x:Uid="Views/LibraryView/FooterButton"
                        Visibility="{x:Bind ViewModel.CanLoadMore, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{x:Bind ViewModel.LoadMoreContentCommand}"
                        Style="{ThemeResource TextBlockButtonStyle}"
                        HorizontalAlignment="Center" Margin="0 8" />
            </ListView.Footer>
        </ListView>
    </Grid>
</local:LibraryViewBase>