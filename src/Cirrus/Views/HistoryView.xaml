<local:HistoryViewBase
    x:Class="Cirrus.Views.HistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Cirrus.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:Cirrus.Behaviors"
    xmlns:communityControls="using:CommunityToolkit.WinUI.Controls"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    mc:Ignorable="d">
    <Grid>
        <interactivity:Interaction.Behaviors>
            <behaviors:LoadedEventTriggerBehavior>
                <interactivity:InvokeCommandAction Command="{x:Bind LoadedCommand}" />
            </behaviors:LoadedEventTriggerBehavior>
            <behaviors:SizeChangedEventTriggerBehavior>
                <interactivity:InvokeCommandAction Command="{x:Bind SizeChangedCommand}" />
                <interactivity:InvokeCommandAction Command="{x:Bind ViewModel.SizeChangedCommand}" />
            </behaviors:SizeChangedEventTriggerBehavior>
        </interactivity:Interaction.Behaviors>
        <Grid Canvas.ZIndex="1" VerticalAlignment="Top">
            <Border x:Name="HeaderFloatingBackBorder"
            Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefault}" BorderThickness="1"
            CornerRadius="8" Height="80" MaxWidth="936" Margin="32 16">
            </Border>
            <Border VerticalAlignment="Center">
                <TextBlock x:Name="HeaderTextBlock" x:Uid="Views/HistoryView/Header"
                   CharacterSpacing="-20" FontSize="24" FontWeight="Bold"
                   VerticalAlignment="Center" />
            </Border>
            <Border VerticalAlignment="Center" HorizontalAlignment="Right">
                <communityControls:Segmented x:Name="ContentCategorySegmented">
                    <!--SelectedIndex="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"-->
                    <communityControls:SegmentedItem x:Uid="Views/HistoryView/Categories/Tracks">
                        <communityControls:SegmentedItem.Icon>
                            <FontIcon Glyph="&#xEC4F;" />
                        </communityControls:SegmentedItem.Icon>
                    </communityControls:SegmentedItem>
                    <communityControls:SegmentedItem x:Uid="Views/HistoryView/Categories/Albums">
                        <communityControls:SegmentedItem.Icon>
                            <FontIcon Glyph="&#xE93C;" />
                        </communityControls:SegmentedItem.Icon>
                    </communityControls:SegmentedItem>
                    <communityControls:SegmentedItem x:Uid="Views/HistoryView/Categories/Playlists">
                        <communityControls:SegmentedItem.Icon>
                            <FontIcon Glyph="{StaticResource FontIconGlyphCollections}" FontFamily="{StaticResource CirrusIconSetFontFamily}" />
                        </communityControls:SegmentedItem.Icon>
                    </communityControls:SegmentedItem>
                </communityControls:Segmented>
            </Border>
        </Grid>
        <ListView x:Name="ContentListView" Padding="8 100 8 80">
            <!--ItemsSource="{x:Bind ViewModel.DisplayItems}"-->
            <!--<ListView.ItemTemplateSelector>
                <themes:LibraryCollectionItemTemplateSelector
            AlbumTemplate="{StaticResource LibraryAlbumItemTemplate}"
            ArtistTemplate="{StaticResource LibraryArtistItemTemplate}" />
            </ListView.ItemTemplateSelector>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>-->
            <!--<ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter Width="{Binding ElementName=CurrentView, Path=ViewModel.DisplayCardWidth, Mode=OneWay}" Padding="8" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>-->
        </ListView>
    </Grid>
</local:HistoryViewBase>
