<local:SearchResultViewBase
    x:Class="Cirrus.Views.SearchResultView"
    x:Name="CurrentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Cirrus.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:behaviors="using:Cirrus.Behaviors"
    xmlns:commanding="using:Cirrus.Commanding"
    xmlns:communityControls="using:CommunityToolkit.WinUI.Controls"
    xmlns:controls="using:Cirrus.Controls"
    xmlns:ctk="using:CommunityToolkit.WinUI"
    xmlns:gsm="using:Cirrus.Models.Network.Response.Search.GeneralSearchModules"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:layout="using:Cirrus.Layout"
    xmlns:liveModels="using:Cirrus.LiveModels"
    xmlns:mAlbum="using:Cirrus.Models.Network.Album"
    xmlns:mArtist="using:Cirrus.Models.Network.Artist"
    xmlns:mPlaylist="using:Cirrus.Models.Network.Playlist"
    xmlns:mTrack="using:Cirrus.Models.Business.Track"
    xmlns:mUser="using:Cirrus.Models.Network.User"
    xmlns:system="using:System"
    xmlns:themes="using:Cirrus.Themes"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="ms-appx:///CommunityToolkit.WinUI.Controls.Segmented/Segmented/Segmented.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <commanding:ShowTrackContextFlyoutCommand x:Name="TopTracksShowContextFlyoutCommand"
                                                      x:Key="TopTracksShowContextFlyoutCommand" />
            <commanding:ShowTrackContextFlyoutCommand x:Name="FullTracksShowContextFlyoutCommand"
                                                      x:Key="FullTracksShowContextFlyoutCommand" />
            <commanding:PlayFromListCommand x:Name="TopTracksPlayFromListCommand"
                                            x:Key="TopTracksPlayFromListCommand" />
            <commanding:PlayFromListCommand x:Name="FullTracksPlayFromListCommand"
                                            x:Key="FullTracksPlayFromListCommand" />
            <DataTemplate x:Key="TopArtistModuleTemplate" x:DataType="gsm:ArtistSearchResultModule">
                <GridView ItemsSource="{x:Bind Artists}" Padding="0">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="mArtist:ArtistDetail">
                            <controls:NavigatiableDisplayCard Style="{StaticResource CircleNavigationDisplayCardStyle}"
                                                              CornerRadius="80"
                                                              Image="{x:Bind AvatarImageUrl, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=320}"
                                                              Title="{x:Bind Name}"
                                                              DataContext="{Binding Mode=OneWay}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid
                                ItemWidth="{Binding ElementName=CurrentView, Path=ViewModel.CircleDisplayCardWidth, Mode=OneWay}"
                                Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridViewItem">
                                        <ContentPresenter Margin="-1 -1 -5 -5" Padding="8" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.Header>
                        <layout:Row Margin="8">
                            <TextBlock x:Uid="Views/SearchResultView/TopResults/ArtistsHeader"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{ThemeResource SystemBaseMediumLowColor}"
                                       VerticalAlignment="Center" />
                            <layout:Spacer layout:Row.ColumnWidth="*" />
                            <Button x:Uid="Views/SearchResultView/ViewMoreButton"
                                    Command="{Binding ElementName=CurrentView, Path=ViewModel.SwitchToCategoryCommand}"
                                    CommandParameter="Artist"
                                    Style="{ThemeResource TextBlockButtonStyle}"
                                    VerticalAlignment="Center" />
                        </layout:Row>
                    </GridView.Header>
                </GridView>
            </DataTemplate>
            <DataTemplate x:Key="TopAlbumModuleTemplate" x:DataType="gsm:AlbumSearchResultModule">
                <GridView ItemsSource="{x:Bind Albums}">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="mAlbum:AlbumDetail">
                            <controls:NavigatiableDisplayCard Title="{x:Bind Title}"
                                                              Subtitle="{x:Bind Artists, Converter={StaticResource MultipleEntityNamesConverter}}"
                                                              Image="{x:Bind ArtworkImageUrl, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=480}"
                                                              DataContext="{Binding Mode=OneWay}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid
                                ItemWidth="{Binding ElementName=CurrentView, Path=ViewModel.SquareDisplayCardWidth, Mode=OneWay}"
                                Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridViewItem">
                                        <ContentPresenter Margin="-1 -1 -5 -5" Padding="8" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.Header>
                        <layout:Row Margin="8">
                            <TextBlock x:Uid="Views/SearchResultView/TopResults/AlbumsHeader"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{ThemeResource SystemBaseMediumLowColor}"
                                       VerticalAlignment="Center" />
                            <layout:Spacer layout:Row.ColumnWidth="*" />
                            <Button x:Uid="Views/SearchResultView/ViewMoreButton"
                                    Command="{Binding ElementName=CurrentView, Path=ViewModel.SwitchToCategoryCommand}"
                                    CommandParameter="Album"
                                    Style="{ThemeResource TextBlockButtonStyle}"
                                    VerticalAlignment="Center" />
                        </layout:Row>
                    </GridView.Header>
                </GridView>
            </DataTemplate>
            <DataTemplate x:Key="TopTrackModuleTemplate" x:DataType="liveModels:TopTracksModule">
                <StackPanel>
                    <layout:Row Margin="8">
                        <TextBlock x:Uid="Views/SearchResultView/TopResults/TracksHeader"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemBaseMediumLowColor}"
                                   VerticalAlignment="Center" />
                        <layout:Spacer layout:Row.ColumnWidth="*" />
                        <Button x:Uid="Views/SearchResultView/ViewMoreButton"
                                Command="{Binding ElementName=CurrentView, Path=ViewModel.SwitchToCategoryCommand}"
                                CommandParameter="Track"
                                Style="{ThemeResource TextBlockButtonStyle}"
                                VerticalAlignment="Center" />
                    </layout:Row>
                    <ListView Style="{StaticResource TrackListViewHorizontalStyle}"
                              SelectionMode="None" Padding="-4 0" Margin="8 0"
                              ItemsSource="{x:Bind Tracks}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="mTrack:OnlineTrack">
                                <controls:TrackListItem Style="{StaticResource LatestTrackListItemStyle}"
                                                        Margin="4"
                                                        DataContext="{Binding}"
                                                        PlayFromListCommand="{StaticResource TopTracksPlayFromListCommand}"
                                                        ShowContextFlyoutCommand="{StaticResource TopTracksShowContextFlyoutCommand}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"
                                               ItemWidth="{Binding ElementName=CurrentView, Path=ViewModel.TrackItemWidth, Mode=OneWay}" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ListView>
                </StackPanel>
            </DataTemplate>
            <DataTemplate x:Key="TopPlaylistModuleTemplate" x:DataType="gsm:PlaylistSearchResultModule">
                <GridView ItemsSource="{x:Bind Playlists}">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="mPlaylist:PlaylistDetail">
                            <controls:NavigatiableDisplayCard Title="{x:Bind Title}"
                                                              Subtitle="{x:Bind Creator.Nickname}"
                                                              Image="{x:Bind CoverImageUrl, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=480}"
                                                              DataContext="{Binding Mode=OneWay}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid
                                ItemWidth="{Binding ElementName=CurrentView, Path=ViewModel.SquareDisplayCardWidth, Mode=OneWay}"
                                Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Control.Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridViewItem">
                                        <ContentPresenter Margin="-1 -1 -5 -5" Padding="8" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.Header>
                        <layout:Row Margin="8">
                            <TextBlock x:Uid="Views/SearchResultView/TopResults/PlaylistsHeader"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{ThemeResource SystemBaseMediumLowColor}"
                                       VerticalAlignment="Center" />
                            <layout:Spacer layout:Row.ColumnWidth="*" />
                            <Button x:Uid="Views/SearchResultView/ViewMoreButton"
                                    Command="{Binding ElementName=CurrentView, Path=ViewModel.SwitchToCategoryCommand}"
                                    CommandParameter="Playlist"
                                    Style="{ThemeResource TextBlockButtonStyle}"
                                    VerticalAlignment="Center" />
                        </layout:Row>
                    </GridView.Header>
                </GridView>
            </DataTemplate>
            <DataTemplate x:Key="TopUserModuleTemplate" x:DataType="gsm:UserSearchResultModule">
                <GridView ItemsSource="{x:Bind Users}" Padding="0">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="mUser:UserProfile">
                            <controls:NavigatiableDisplayCard Style="{StaticResource CircleNavigationDisplayCardStyle}"
                                                              CornerRadius="80"
                                                              Image="{x:Bind AvatarImageUrl, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=320}"
                                                              Title="{x:Bind Nickname}"
                                                              DataContext="{Binding Mode=OneWay}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid
                                ItemWidth="{Binding ElementName=CurrentView, Path=ViewModel.CircleDisplayCardWidth, Mode=OneWay}"
                                Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridViewItem">
                                        <ContentPresenter Margin="-1 -1 -5 -5" Padding="8" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.Header>
                        <layout:Row Margin="8">
                            <TextBlock x:Uid="Views/SearchResultView/TopResults/ProfilesHeader"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{ThemeResource SystemBaseMediumLowColor}"
                                       VerticalAlignment="Center" />
                            <layout:Spacer layout:Row.ColumnWidth="*" />
                            <Button x:Uid="Views/SearchResultView/ViewMoreButton"
                                    Command="{Binding ElementName=CurrentView, Path=ViewModel.SwitchToCategoryCommand}"
                                    CommandParameter="User"
                                    Style="{ThemeResource TextBlockButtonStyle}"
                                    VerticalAlignment="Center" />
                        </layout:Row>
                    </GridView.Header>
                </GridView>
            </DataTemplate>
            <DataTemplate x:Key="QuerySuggestionsModuleTemplate" x:DataType="gsm:SimilarQuerySuggestionsModule">
                <StackPanel>
                    <TextBlock x:Uid="Views/SearchResultView/TopResults/QuerySuggestionsHeader"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemBaseMediumLowColor}"
                               Margin="8" />
                    <ItemsRepeater ItemsSource="{x:Bind Keywords}"
                                   Margin="8">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="system:String">
                                <Button Content="{Binding}"
                                        Command="{StaticResource NavigateCommand}"
                                        CommandParameter="{Binding Converter={StaticResource StringQueryConverter}}"
                                        Style="{StaticResource AccentGlowButtonStyle}"
                                        FontSize="14" Height="32" MinWidth="40" CornerRadius="16" Padding="12 0"
                                        VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                        <ItemsRepeater.Layout>
                            <communityControls:WrapLayout HorizontalSpacing="8" VerticalSpacing="8" />
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>
            </DataTemplate>
            <DataTemplate x:Key="ArtistTemplate" x:DataType="mArtist:ArtistDetail">
                <controls:NavigatiableDisplayCard Style="{StaticResource CircleNavigationDisplayCardStyle}"
                                                  CornerRadius="80"
                                                  Image="{x:Bind AvatarImageUrl, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=320}"
                                                  Title="{x:Bind Name}"
                                                  DataContext="{Binding Mode=OneWay}" />
            </DataTemplate>
            <DataTemplate x:Key="AlbumTemplate" x:DataType="mAlbum:AlbumDetail">
                <controls:NavigatiableDisplayCard Title="{x:Bind Title}"
                                                  Subtitle="{x:Bind Artists, Converter={StaticResource MultipleEntityNamesConverter}}"
                                                  Image="{x:Bind ArtworkImageUrl, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=480}"
                                                  DataContext="{Binding Mode=OneWay}" />
            </DataTemplate>
            <DataTemplate x:Key="TrackTemplate" x:DataType="mTrack:OnlineTrack">
                <controls:TrackListItem Style="{StaticResource TrackSearchResultListItemStyle}"
                                        DataContext="{Binding}"
                                        PlayFromListCommand="{StaticResource FullTracksPlayFromListCommand}"
                                        ShowContextFlyoutCommand="{StaticResource FullTracksShowContextFlyoutCommand}" />
            </DataTemplate>
            <DataTemplate x:Key="PlaylistTemplate" x:DataType="mPlaylist:PlaylistDetail">
                <controls:NavigatiableDisplayCard Title="{x:Bind Title}"
                                                  Subtitle="{x:Bind Creator.Nickname}"
                                                  Image="{x:Bind CoverImageUrl, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=480}"
                                                  DataContext="{Binding Mode=OneWay}" />
            </DataTemplate>
            <DataTemplate x:Key="UserTemplate" x:DataType="mUser:UserProfile">
                <controls:NavigatiableDisplayCard Style="{StaticResource CircleNavigationDisplayCardStyle}"
                                                  CornerRadius="80"
                                                  Image="{x:Bind AvatarImageUrl, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=320}"
                                                  Title="{x:Bind Nickname}"
                                                  DataContext="{Binding Mode=OneWay}" />
            </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>
    <Grid>
        <interactivity:Interaction.Behaviors>
            <behaviors:LoadedEventTriggerBehavior>
                <interactivity:InvokeCommandAction Command="{x:Bind LoadedCommand}" />
            </behaviors:LoadedEventTriggerBehavior>
            <behaviors:SizeChangedEventTriggerBehavior>
                <interactivity:InvokeCommandAction Command="{x:Bind ViewModel.SizeChangedCommand}" />
            </behaviors:SizeChangedEventTriggerBehavior>
        </interactivity:Interaction.Behaviors>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState>
                    <VisualState.StateTriggers>
                        <ctk:IsEqualStateTrigger Value="{x:Bind ViewModel.SelectedCategory, Mode=OneWay}"
                                                 To="1" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ResultListView.ItemsPanel">
                            <Setter.Value>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid
                                        ItemWidth="{Binding ElementName=CurrentView, Path=ViewModel.CircleDisplayCardWidth, Mode=OneWay}"
                                        Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Target="ResultListView.ItemContainerStyle">
                            <Setter.Value>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter Padding="8" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Setter.Value>
                        </Setter>
                    </VisualState.Setters>
                </VisualState>
                <VisualState>
                    <VisualState.StateTriggers>
                        <ctk:IsEqualStateTrigger Value="{x:Bind ViewModel.SelectedCategory, Mode=OneWay}"
                                                 To="2" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ResultListView.ItemsPanel">
                            <Setter.Value>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid
                                        ItemWidth="{Binding ElementName=CurrentView, Path=ViewModel.SquareDisplayCardWidth, Mode=OneWay}"
                                        Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Target="ResultListView.ItemContainerStyle">
                            <Setter.Value>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter Margin="0" Padding="8" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Setter.Value>
                        </Setter>
                    </VisualState.Setters>
                </VisualState>
                <VisualState>
                    <VisualState.StateTriggers>
                        <ctk:IsEqualStateTrigger Value="{x:Bind ViewModel.SelectedCategory, Mode=OneWay}"
                                                 To="3" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ResultListView.Padding" Value="16 16 16 80" />
                        <Setter Target="ViewHeader.Margin" Value="16" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState>
                    <VisualState.StateTriggers>
                        <ctk:IsEqualStateTrigger Value="{x:Bind ViewModel.SelectedCategory, Mode=OneWay}"
                                                 To="4" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ResultListView.ItemsPanel">
                            <Setter.Value>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid
                                        ItemWidth="{Binding ElementName=CurrentView, Path=ViewModel.SquareDisplayCardWidth, Mode=OneWay}"
                                        Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Target="ResultListView.ItemContainerStyle">
                            <Setter.Value>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter Margin="0" Padding="8" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Setter.Value>
                        </Setter>
                    </VisualState.Setters>
                </VisualState>
                <VisualState>
                    <VisualState.StateTriggers>
                        <ctk:IsEqualStateTrigger Value="{x:Bind ViewModel.SelectedCategory, Mode=OneWay}"
                                                 To="5" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ResultListView.ItemsPanel">
                            <Setter.Value>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid
                                        ItemWidth="{Binding ElementName=CurrentView, Path=ViewModel.CircleDisplayCardWidth, Mode=OneWay}"
                                        Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Target="ResultListView.ItemContainerStyle">
                            <Setter.Value>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter Padding="8" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Setter.Value>
                        </Setter>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <ProgressBar VerticalAlignment="Top" Canvas.ZIndex="2"
                     Background="Transparent"
                     IsIndeterminate="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        <StackPanel x:Name="FloatingHeader"
                    Visibility="Collapsed" Canvas.ZIndex="1"
                    VerticalAlignment="Top" HorizontalAlignment="Stretch" MaxWidth="1000"
                    Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="4" Margin="32 16" Padding="24" Spacing="16">
            <animations:Implicit.ShowAnimations>
                <animations:TranslationAnimation From="0,-120,0" To="0" Duration="0:0:0.300" />
            </animations:Implicit.ShowAnimations>
            <animations:Implicit.HideAnimations>
                <animations:TranslationAnimation From="0" To="0,-120,0" Duration="0:0:0.300" />
            </animations:Implicit.HideAnimations>
            <TextBlock
                Text="{x:Bind ViewModel.Parameter, Converter={StaticResource LanguageResourceConverter}, ConverterParameter=Views/SearchResultView/Header/Format, Mode=OneWay}"
                TextTrimming="CharacterEllipsis"
                CharacterSpacing="-20" FontSize="24" FontWeight="Bold" />
            <communityControls:Segmented Style="{ThemeResource ButtonSegmentedStyle}"
                                         SelectedIndex="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <communityControls:Segmented.Items>
                    <communityControls:SegmentedItem x:Uid="Views/SearchResultView/Categories/TopResultsSegmentedItem">
                        <communityControls:SegmentedItem.Icon>
                            <FontIcon Glyph="&#xECAD;" />
                        </communityControls:SegmentedItem.Icon>
                    </communityControls:SegmentedItem>
                    <communityControls:SegmentedItem x:Uid="Views/SearchResultView/Categories/ArtistsSegmentedItem">
                        <communityControls:SegmentedItem.Icon>
                            <FontIcon Glyph="{ThemeResource FontIconGlyphArtist}"
                                      FontFamily="{ThemeResource CirrusIconSetFontFamily}" />
                        </communityControls:SegmentedItem.Icon>
                    </communityControls:SegmentedItem>
                    <communityControls:SegmentedItem x:Uid="Views/SearchResultView/Categories/AlbumsSegmentedItem">
                        <communityControls:SegmentedItem.Icon>
                            <FontIcon Glyph="&#xE93C;" />
                        </communityControls:SegmentedItem.Icon>
                    </communityControls:SegmentedItem>
                    <communityControls:SegmentedItem x:Uid="Views/SearchResultView/Categories/TracksSegmentedItem">
                        <communityControls:SegmentedItem.Icon>
                            <FontIcon Glyph="&#xEC4F;" />
                        </communityControls:SegmentedItem.Icon>
                    </communityControls:SegmentedItem>
                    <communityControls:SegmentedItem x:Uid="Views/SearchResultView/Categories/PlaylistsSegmentedItem">
                        <communityControls:SegmentedItem.Icon>
                            <FontIcon Glyph="{ThemeResource FontIconGlyphAppsListDetail}"
                                      FontFamily="{ThemeResource CirrusIconSetFontFamily}" />
                        </communityControls:SegmentedItem.Icon>
                    </communityControls:SegmentedItem>
                    <communityControls:SegmentedItem x:Uid="Views/SearchResultView/Categories/ProfilesSegmentedItem">
                        <communityControls:SegmentedItem.Icon>
                            <FontIcon Glyph="&#xE716;" />
                        </communityControls:SegmentedItem.Icon>
                    </communityControls:SegmentedItem>
                </communityControls:Segmented.Items>
            </communityControls:Segmented>
        </StackPanel>
        <ListView x:Name="ResultListView"
                  ItemsSource="{x:Bind ViewModel.DisplayItems}"
                  Padding="8 8 8 80"
                  SelectionMode="None">
            <ListView.Header>
                <StackPanel x:Name="ViewHeader"
                            Margin="24 24 24 16" Spacing="16">
                    <TextBlock
                        Text="{x:Bind ViewModel.Parameter, Converter={StaticResource LanguageResourceConverter}, ConverterParameter=Views/SearchResultView/Header/Format, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        CharacterSpacing="-20" FontSize="24" FontWeight="Bold" />
                    <communityControls:Segmented Style="{ThemeResource ButtonSegmentedStyle}"
                                                 SelectedIndex="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <communityControls:Segmented.Items>
                            <communityControls:SegmentedItem
                                x:Uid="Views/SearchResultView/Categories/TopResultsSegmentedItem">
                                <communityControls:SegmentedItem.Icon>
                                    <FontIcon Glyph="&#xECAD;" />
                                </communityControls:SegmentedItem.Icon>
                            </communityControls:SegmentedItem>
                            <communityControls:SegmentedItem
                                x:Uid="Views/SearchResultView/Categories/ArtistsSegmentedItem">
                                <communityControls:SegmentedItem.Icon>
                                    <FontIcon Glyph="{ThemeResource FontIconGlyphArtist}"
                                              FontFamily="{ThemeResource CirrusIconSetFontFamily}" />
                                </communityControls:SegmentedItem.Icon>
                            </communityControls:SegmentedItem>
                            <communityControls:SegmentedItem
                                x:Uid="Views/SearchResultView/Categories/AlbumsSegmentedItem">
                                <communityControls:SegmentedItem.Icon>
                                    <FontIcon Glyph="&#xE93C;" />
                                </communityControls:SegmentedItem.Icon>
                            </communityControls:SegmentedItem>
                            <communityControls:SegmentedItem
                                x:Uid="Views/SearchResultView/Categories/TracksSegmentedItem">
                                <communityControls:SegmentedItem.Icon>
                                    <FontIcon Glyph="&#xEC4F;" />
                                </communityControls:SegmentedItem.Icon>
                            </communityControls:SegmentedItem>
                            <communityControls:SegmentedItem
                                x:Uid="Views/SearchResultView/Categories/PlaylistsSegmentedItem">
                                <communityControls:SegmentedItem.Icon>
                                    <FontIcon Glyph="{ThemeResource FontIconGlyphAppsListDetail}"
                                              FontFamily="{ThemeResource CirrusIconSetFontFamily}" />
                                </communityControls:SegmentedItem.Icon>
                            </communityControls:SegmentedItem>
                            <communityControls:SegmentedItem
                                x:Uid="Views/SearchResultView/Categories/ProfilesSegmentedItem">
                                <communityControls:SegmentedItem.Icon>
                                    <FontIcon Glyph="&#xE716;" />
                                </communityControls:SegmentedItem.Icon>
                            </communityControls:SegmentedItem>
                        </communityControls:Segmented.Items>
                    </communityControls:Segmented>
                </StackPanel>
            </ListView.Header>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter Padding="0" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplateSelector>
                <themes:SearchResultItemTemplateSelector
                    TopArtistModuleTemplate="{StaticResource TopArtistModuleTemplate}"
                    TopAlbumModuleTemplate="{StaticResource TopAlbumModuleTemplate}"
                    TopTrackModuleTemplate="{StaticResource TopTrackModuleTemplate}"
                    TopPlaylistModuleTemplate="{StaticResource TopPlaylistModuleTemplate}"
                    TopUserModuleTemplate="{StaticResource TopUserModuleTemplate}"
                    QuerySuggestionsModuleTemplate="{StaticResource QuerySuggestionsModuleTemplate}"
                    ArtistTemplate="{StaticResource ArtistTemplate}"
                    AlbumTemplate="{StaticResource AlbumTemplate}"
                    TrackTemplate="{StaticResource TrackTemplate}"
                    PlaylistTemplate="{StaticResource PlaylistTemplate}"
                    UserTemplate="{StaticResource UserTemplate}" />
            </ListView.ItemTemplateSelector>
            <ListView.Footer>
                <Button x:Uid="Views/SearchResultView/LoadMoreButton"
                        Command="{x:Bind ViewModel.LoadMoreCommand}"
                        Visibility="{x:Bind ViewModel.CanLoadMore, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Style="{ThemeResource TextBlockButtonStyle}"
                        Margin="16" HorizontalAlignment="Center" />
            </ListView.Footer>
        </ListView>
    </Grid>
</local:SearchResultViewBase>