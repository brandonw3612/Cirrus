<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Cirrus.Controls">
    <Style TargetType="local:SidebarMenuButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:SidebarMenuButton">
                    <Border x:Name="RootBorder" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
                            CornerRadius="8" BorderThickness="1">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootBorderBackgroundBrush.Color"
                                                Value="{ThemeResource SystemBaseLowColor}" />
                                        <Setter Target="RootBorderBorderBrush.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootBorderBackgroundBrush.Color"
                                                Value="{ThemeResource SystemBaseMediumLowColor}" />
                                        <Setter Target="RootBorderBorderBrush.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="SelectionStates">
                                <VisualState x:Name="Unselected">
                                    <VisualState.Setters>
                                        <Setter Target="HighlightBorderBackgroundBrush.Opacity" Value="0" />
                                    </VisualState.Setters>
                                    <VisualState.Storyboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HighlightBorderBackgroundBrush"
                                                             Storyboard.TargetProperty="Opacity"
                                                             Duration="0:0:0.2" To="0" />
                                        </Storyboard>
                                    </VisualState.Storyboard>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Target="HighlightBorderBackgroundBrush.Opacity" Value="1" />
                                    </VisualState.Setters>
                                    <VisualState.Storyboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HighlightBorderBackgroundBrush"
                                                             Storyboard.TargetProperty="Opacity"
                                                             Duration="0:0:0.2" To="1" />
                                        </Storyboard>
                                    </VisualState.Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="RootBorderBorderBrush"
                                             Color="{ThemeResource CardStrokeColorDefault}" Opacity="0" />
                        </Border.BorderBrush>
                        <Border.Background>
                            <SolidColorBrush x:Name="RootBorderBackgroundBrush" Color="Transparent" Opacity="0.1" />
                        </Border.Background>
                        <Border x:Name="HighlightBorder" CornerRadius="8">
                            <Border.Background>
                                <SolidColorBrush x:Name="HighlightBorderBackgroundBrush"
                                                 Color="{ThemeResource CardBackgroundFillColorDefault}" Opacity="0" />
                            </Border.Background>
                            <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Center" Spacing="4">
                                <ImageIcon x:Name="Icon" Source="{TemplateBinding MenuIconSource}"
                                           Width="{TemplateBinding IconWidth}" Height="{TemplateBinding IconHeight}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Opacity="0.75" Text="{TemplateBinding Caption}" HorizontalAlignment="Center"
                                           FontSize="10" />
                            </StackPanel>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>