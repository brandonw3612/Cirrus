<UserControl
    x:Class="Cirrus.Controls.QuickAccessView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:businessPlaylist="using:Cirrus.Models.Business.Playlist"
    mc:Ignorable="d">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="ThemeGradientBrush" StartPoint="0,0" EndPoint="1,1" Opacity="0.8">
            <GradientStop Color="#33E0FF" Offset="0" />
            <GradientStop Color="#0070CC" Offset="1" />
        </LinearGradientBrush>
    </UserControl.Resources>
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="Collapsed">
            <FontIcon FontSize="100" Glyph="{StaticResource FontIconGlyphCollectionsFilled}"
                      FontFamily="{StaticResource CirrusIconSetFontFamily}" Opacity="0.75"
                      HorizontalAlignment="Center" Foreground="{StaticResource ThemeGradientBrush}" />
            <TextBlock HorizontalAlignment="Center" Foreground="{ThemeResource SystemBaseMediumLowColor}"
                       TextWrapping="Wrap" TextAlignment="Center" Margin="0 8 0 16">To see your recent playlists here, you need to log in.</TextBlock>
            <Button Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Center" Padding="8 4"
                    Command="{x:Bind ShowLoginDialogCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE910;" FontSize="14" />
                    <TextBlock>Log in</TextBlock>
                </StackPanel>
            </Button>
        </StackPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Margin="8 8 8 0" Orientation="Horizontal" Spacing="4">
                <Button Command="{x:Bind Account.QuickAccessPlaylists.RefreshCommand}" Width="32" Height="32" Padding="0">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                </Button>
                <Button Command="{x:Bind Account.QuickAccessPlaylists.RefreshCommand}" Width="32" Height="32" Padding="0">
                    <FontIcon Glyph="&#xE72C;" FontSize="12" />
                </Button>
            </StackPanel>
            <Button Grid.Row="1" CornerRadius="4" Margin="8" Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Command="{StaticResource NavigateCommand}" CommandParameter="{x:Bind Account.QuickAccessPlaylists.FavList, Mode=OneWay}"
                    Style="{ThemeResource CardButtonStyle}">
                <Grid ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Height="48" Width="48" CornerRadius="4 0 0 4" Background="{StaticResource ThemeGradientBrush}"
                            BorderThickness="0 0 1 0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Image Source="{x:Bind Account.UserProfile.AvatarImageUrl, Mode=OneWay, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=72}" />
                        </Border>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock FontSize="14">My Favorites</TextBlock>
                        <TextBlock Text="{x:Bind Account.UserProfile.Nickname, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource SystemBaseMediumColor}" />
                    </StackPanel>
                </Grid>
            </Button>
            <ListView Grid.Row="2" Padding="6 0 14 0"
                      ItemsSource="{x:Bind Account.QuickAccessPlaylists.Playlists, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="businessPlaylist:QuickAccessPlaylist">
                        <Button CornerRadius="4" Padding="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                Command="{StaticResource NavigateCommand}" CommandParameter="{Binding Mode=OneWay}"
                                Style="{ThemeResource TextBlockButtonStyle}">
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Height="32" Width="32" CornerRadius="4" Background="{StaticResource CardBackgroundFillColorDefaultBrush}"
                                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                    <Image Source="{x:Bind CoverImageUrl, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=64}" Margin="-1" />
                                </Border>
                                <TextBlock Grid.Column="1" FontSize="12" Text="{x:Bind Title}"
                                           Foreground="{ThemeResource SystemBaseMediumColor}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate>
                                    <ContentPresenter Margin="0 1" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
