<UserControl
    x:Class="Cirrus.Controls.FluidBackground"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Cirrus.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win2d="using:Microsoft.Graphics.Canvas.UI.Xaml"
    mc:Ignorable="d">
    <win2d:CanvasAnimatedControl
        x:Name="BackgroundPresenter"
        CreateResources="BackgroundPresenter_CreateResources"
        Draw="BackgroundPresenter_Draw"
        Opacity="0.75"
        Update="BackgroundPresenter_Update" />
</UserControl>