<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Cirrus.Controls">
    <Style TargetType="local:KeyboardRecordBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:KeyboardRecordBox">
                    <Button BorderThickness="0" Padding="0" Width="{TemplateBinding Width}" Height="40">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                        </Button.Resources>
                        <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                              CornerRadius="4" Height="40" Width="{TemplateBinding Width}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <ItemsRepeater x:Name="KeyItemsRepeater" Margin="4 0" VerticalAlignment="Center"
                                           ItemsSource="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=DisplayedKeys, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="4" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="1"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                Padding="8 0" Height="30" CornerRadius="4">
                                            <TextBlock Text="{Binding Path=Label, Mode=OneWay}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                            <TextBlock Grid.Column="0" Foreground="{ThemeResource SystemErrorTextColor}"
                                       VerticalAlignment="Center" Margin="8 0"
                                       Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.WarningText, Mode=OneWay}"
                                       Visibility="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.IsWarningVisible, Mode=OneWay}" />
                            <Border x:Name="KeyStatusBorder" Grid.Column="1" Width="24" Height="24" CornerRadius="12"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.IsKeysStatusVisible, Mode=OneWay}">
                                <Border.Background>
                                    <SolidColorBrush
                                        Color="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.KeysStatusBackgroundColor, Mode=OneWay}"
                                        Opacity="0.6" />
                                </Border.Background>
                                <FontIcon x:Name="KeyStatusFontIcon" FontSize="16" Foreground="White"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Glyph="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.KeysStatusFontIconGlyph, Mode=OneWay}" />
                            </Border>
                            <Button x:Name="ClearButton" Grid.Column="2" Width="32" Height="32"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                    AllowFocusOnInteraction="False" Padding="0" VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ClearKeysCommand}">
                                <FontIcon Glyph="&#xE711;" FontSize="16"
                                          Foreground="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" />
                            </Button>
                        </Grid>
                    </Button>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>