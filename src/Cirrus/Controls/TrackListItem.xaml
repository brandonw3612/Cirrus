<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Cirrus.Controls"
    xmlns:behaviors="using:Cirrus.Behaviors"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:layout="using:Cirrus.Layout"
    xmlns:primitives="using:Cirrus.Behaviors.Primitives">
    <Style TargetType="local:TrackListItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:TrackListItem">
                    <Grid x:Name="RootGrid"
                          Background="Transparent"
                          Height="56" Margin="2" Padding="8 2" ColumnSpacing="8" CornerRadius="4"
                          BorderThickness="1" BorderBrush="Transparent">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup>
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background"
                                                Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                                        <Setter Target="RootGrid.BorderBrush"
                                                Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                                        <Setter Target="PlayButton.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background"
                                                Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                                        <Setter Target="RootGrid.BorderBrush"
                                                Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                                        <Setter Target="PlayButton.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <interactivity:Interaction.Behaviors>
                            <behaviors:PointerEnteredEventTriggerBehavior>
                                <interactivity:GoToStateAction StateName="PointerOver" />
                            </behaviors:PointerEnteredEventTriggerBehavior>
                            <behaviors:PointerPressedEventTriggerBehavior>
                                <interactivity:GoToStateAction StateName="Pressed" />
                            </behaviors:PointerPressedEventTriggerBehavior>
                            <behaviors:PointerReleasedEventTriggerBehavior>
                                <interactivity:GoToStateAction StateName="PointerOver" />
                            </behaviors:PointerReleasedEventTriggerBehavior>
                            <behaviors:PointerExitedEventTriggerBehavior>
                                <interactivity:GoToStateAction StateName="Normal" />
                            </behaviors:PointerExitedEventTriggerBehavior>
                            <behaviors:PointerCaptureLostEventTriggerBehavior>
                                <interactivity:GoToStateAction StateName="Normal" />
                            </behaviors:PointerCaptureLostEventTriggerBehavior>
                            <behaviors:RightTappedEventTriggerBehavior>
                                <behaviors:InvokeCommandActionEx
                                    Command="{Binding Path=ShowContextFlyoutCommand, RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}" />
                                <interactivity:InvokeCommandAction Command="{StaticResource BlockEventPassCommand}" />
                            </behaviors:RightTappedEventTriggerBehavior>
                            <behaviors:TappedEventTriggerBehavior>
                                <behaviors:TappedEventTriggerBehavior.EventTriggerFilter>
                                    <primitives:DisjunctiveEventTriggerFilter>
                                        <primitives:PointerDeviceTypeAllowEventTriggerFilter DeviceType="Touch" />
                                        <primitives:PointerDeviceTypeAllowEventTriggerFilter DeviceType="Pen" />
                                    </primitives:DisjunctiveEventTriggerFilter>
                                </behaviors:TappedEventTriggerBehavior.EventTriggerFilter>
                                <interactivity:InvokeCommandAction
                                    Command="{Binding Path=PlayFromListCommand, RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}"
                                    CommandParameter="{Binding Path=DataContext, RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}" />
                            </behaviors:TappedEventTriggerBehavior>
                            <behaviors:DoubleTappedEventTriggerBehavior>
                                <behaviors:DoubleTappedEventTriggerBehavior.EventTriggerFilter>
                                    <primitives:DisjunctiveEventTriggerFilter>
                                        <primitives:PointerDeviceTypeAllowEventTriggerFilter DeviceType="Mouse" />
                                        <primitives:PointerDeviceTypeAllowEventTriggerFilter DeviceType="Pen" />
                                    </primitives:DisjunctiveEventTriggerFilter>
                                </behaviors:DoubleTappedEventTriggerBehavior.EventTriggerFilter>
                                <interactivity:InvokeCommandAction
                                    Command="{Binding Path=PlayFromListCommand, RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}"
                                    CommandParameter="{Binding Path=DataContext, RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay}" />
                            </behaviors:DoubleTappedEventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{TemplateBinding Index}"
                                   TextTrimming="CharacterEllipsis" CharacterSpacing="-20"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="{ThemeResource SystemBaseMediumColor}" />
                        <Border Grid.Column="1" Width="48" Height="48" CornerRadius="4"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Image
                                Source="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.AlbumArtworkUrl, Mode=OneWay, Converter={StaticResource NeteaseImageResizeConverter}, ConverterParameter=192}"
                                Width="48" Height="48" Stretch="Uniform" />
                        </Border>
                        <layout:Row Grid.Column="2" Spacing="8">
                            <StackPanel VerticalAlignment="Center">
                                <layout:Row x:Name="TitleRow" Spacing="2">
                                    <TextBlock x:Name="TitleTextBlock"
                                               Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.Title, Mode=OneWay}"
                                               RelativePanel.AlignVerticalCenterWithPanel="True"
                                               TextTrimming="CharacterEllipsis" CharacterSpacing="-20" />
                                    <FontIcon Glyph="{ThemeResource FontIconGlyphExplicit}"
                                              FontFamily="{StaticResource CirrusIconSetFontFamily}"
                                              Visibility="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.IsExplicit, Converter={StaticResource BoolToVisibilityConverter}}"
                                              Foreground="{ThemeResource ExplicitIconForeground}"
                                              FontSize="16"
                                              layout:Row.Priority="1" />
                                </layout:Row>
                                <TextBlock
                                    Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.Subtitle, Mode=OneWay}"
                                    FontSize="12" TextTrimming="CharacterEllipsis"
                                    Foreground="{ThemeResource SystemBaseMediumLowColor}"
                                    Visibility="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.Subtitle, Mode=OneWay, Converter={StaticResource EmptyObjectJudgeConverter}}" />
                            </StackPanel>
                            <Button x:Name="PlayButton"
                                    Command="{TemplateBinding PlayFromListCommand}"
                                    CommandParameter="{TemplateBinding DataContext}"
                                    Width="32" Height="32" CornerRadius="4" Padding="0"
                                    layout:Row.Priority="1"
                                    Visibility="Collapsed">
                                <FontIcon Glyph="{StaticResource FontIconGlyphPlayFilled}" FontSize="20"
                                          FontFamily="{ThemeResource CirrusIconSetFontFamily}"
                                          Foreground="{ThemeResource SystemBaseMediumHighColor}" />
                            </Button>
                        </layout:Row>
                        <Button Grid.Column="3" Style="{StaticResource TextBlockButtonStyle}" Margin="-4 -2"
                                Padding="4 2" CornerRadius="4"
                                DataContext="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.Artists, Mode=OneWay}">
                            <TextBlock
                                Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.Artists, Mode=OneWay, Converter={StaticResource MultipleEntityNamesConverter}}"
                                Foreground="{ThemeResource SystemBaseMediumHighColor}" TextWrapping="Wrap" MaxLines="2"
                                TextTrimming="CharacterEllipsis" CharacterSpacing="-20" />
                            <interactivity:Interaction.Behaviors>
                                <behaviors:TappedEventTriggerBehavior>
                                    <behaviors:InvokeCommandActionEx
                                        Command="{StaticResource MultipleTargetNavigateCommand}" />
                                </behaviors:TappedEventTriggerBehavior>
                            </interactivity:Interaction.Behaviors>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource TextBlockButtonStyle}" Margin="-4 -2"
                                Padding="4 2" CornerRadius="4"
                                Command="{StaticResource NavigateCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.Album, Mode=OneWay}">
                            <TextBlock
                                Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.AlbumTitle, Mode=OneWay}"
                                Foreground="{ThemeResource SystemBaseMediumHighColor}" TextWrapping="Wrap" MaxLines="2"
                                TextTrimming="CharacterEllipsis" CharacterSpacing="-20" />
                        </Button>
                        <TextBlock Grid.Column="5"
                                   Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=ViewModel.Duration, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis" CharacterSpacing="-20" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource SystemBaseMediumColor}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
