<UserControl
    x:Class="Cirrus.Controls.LyricLineControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:Cirrus.Behaviors"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    mc:Ignorable="d">
    <Grid HorizontalAlignment="Left" CornerRadius="8" Margin="0 -8">
        <Border x:Name="BackgroundBorder"
                Background="{ThemeResource SystemAltMediumColor}"
                Opacity="0" />
        <StackPanel VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Margin="8">
            <Grid x:Name="B2BGrid"
                  HorizontalAlignment="Stretch">
                <TextBlock x:Name="B2BBackTextBlock"
                           Text="{x:Bind _lineFullString}"
                           TextWrapping="Wrap" FontWeight="Bold" FontSize="{x:Bind BaseFontSize, Mode=OneWay}"
                           HorizontalAlignment="Left"
                           Opacity="0.6">
                    <interactivity:Interaction.Behaviors>
                        <behaviors:SizeChangedEventTriggerBehavior>
                            <interactivity:InvokeCommandAction Command="{x:Bind B2BSizeChangedCommand}" />
                        </behaviors:SizeChangedEventTriggerBehavior>
                    </interactivity:Interaction.Behaviors>
                </TextBlock>
                <StackPanel x:Name="B2BHiddenPanel" />
                <StackPanel x:Name="B2BHighlightPanel" HorizontalAlignment="Stretch" />
            </Grid>
            <TextBlock x:Name="FallbackLineTextBlock"
                       Text="{x:Bind FallbackLine}"
                       TextWrapping="Wrap" FontWeight="Bold" FontSize="{x:Bind BaseFontSize, Mode=OneWay}"
                       Opacity="0.6"
                       Visibility="Visible" />
            <TextBlock x:Name="TranslationTextBlock"
                       Text="{x:Bind _translatedLine}"
                       TextWrapping="Wrap" FontWeight="Bold"
                       Visibility="Visible" Opacity="0.6" Margin="0 4 0 0" />
        </StackPanel>
    </Grid>
</UserControl>